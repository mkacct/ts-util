{
	"compilerOptions": {
		"rootDir": "./src",
		"target": "ES2020",
		"module": "NodeNext",
		"types": ["node"],
		"moduleResolution": "nodenext",
		"outDir": "./build",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"declaration": true,
		"noImplicitOverride": true,
		"noUncheckedIndexedAccess": true
	}
}
